{
	"name": "tailcat",
	"version": "2.0.0",
	"description": "Utility to watch a file and emit the changes",
	"main": "lib/index.js",
	"types": "lib/index.d.ts",
	"exports": {
		".": {
			"types": "./lib/index.d.ts",
			"require": "./lib/index.js",
			"default": "./lib/index.js"
		}
	},
	"packageManager": "npm@11.11.0",
	"scripts": {
		"format": "prettier --write \"source/**/*.ts\" \"test/**/*.ts\"",
		"build": "npm run clean && tsc -p tsconfig.json",
		"test": "npm run build && node --import tsx --test --test-force-exit test/test.ts",
		"clean": "node -e \"require('node:fs').rmSync('lib',{recursive:true,force:true})\"",
		"build-lib": "npm test",
		"deploy": "npm run build-lib && np"
	},
	"engines": {
		"node": ">=22"
	},
	"keywords": [
		"fs",
		"file",
		"watch file",
		"tail",
		"log"
	],
	"repository": "simonjang/tailcat",
	"files": [
		"lib"
	],
	"author": {
		"name": "Simon Jang",
		"email": "simon.jang.contact@gmail.com"
	},
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^26.0.0",
		"np": "^11.2.1",
		"prettier": "^3.8.4",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3"
	}
}
